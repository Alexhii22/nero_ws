<robot name="nero_description">
    <link name="world"/>

    <!-- Central Pillar -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.435" rpy="0 0 0"/>
            <geometry>
                <box size="0.08 0.08 0.87"/>
            </geometry>
            <material name="grey">
                <color rgba="0.5 0.5 0.5 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0.435" rpy="0 0 0"/>
            <geometry>
                <box size="0.08 0.08 0.87"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.435" rpy="0 0 0"/>
            <mass value="5.0"/>
            <inertia ixx="0.32" ixy="0" ixz="0" iyy="0.32" iyz="0" izz="0.01"/>
        </inertial>
    </link>

    <joint name="world_to_base_link" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- LEFT ARM -->
    <link name="left_base_link">
        <inertial>
            <origin xyz="-0.009636 0.000168 0.044860" rpy="0 0 0"/>
            <mass value="0.77"/>
            <inertia ixx="0.0006669" ixy="0.0" ixz="0.0" iyy="0.00054501" iyz="0.0" izz="0.00051509"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://nero_description/meshes/dae/base_link.dae"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://nero_description/meshes/base_link.STL"/>
            </geometry>
        </collision>
    </link>

    <joint name="left_arm_mount" type="fixed">
        <parent link="base_link"/>
        <child link="left_base_link"/>
        <origin xyz="0 -0.062 0.8" rpy="1.5708 0 0"/>
