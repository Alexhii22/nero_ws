    <!-- gazebo_ros2_control: 与 Isaac BI_NERO_HIGH_PD_CFG 一致 (effort 接口, stiffness=400, damping=180, effort_limit=40, disable_gravity) -->
    <gazebo reference="base_link"><turnGravityOff>true</turnGravityOff></gazebo>
    <gazebo reference="left_base_link"><turnGravityOff>true</turnGravityOff></gazebo>
    <gazebo reference="left_link1"><turnGravityOff>true</turnGravityOff></gazebo>
    <gazebo reference="left_link2"><turnGravityOff>true</turnGravityOff></gazebo>
