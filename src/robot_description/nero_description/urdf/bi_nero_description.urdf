        </joint>
        <joint name="right_joint6">
            <command_interface name="position"><param name="min">-0.73</param><param name="max">0.95</param></command_interface>
            <state_interface name="position"/><state_interface name="velocity"/>
        </joint>
        <joint name="right_joint7">
            <command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface>
            <state_interface name="position"/><state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
            <parameters>GAZEBO_ROS2_CONTROL_CONFIG_PATH</parameters>
            <robot_param_node>robot_state_publisher</robot_param_node>
        </plugin>
    </gazebo>

</robot>
