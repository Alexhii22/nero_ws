    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>
        <!-- position command_interface: 配合 joint_trajectory_controller (JTC) -->
        <!-- JTC 接收位置目标 + 到达时间，内部做插值平滑，输出中间位置到 position 接口 -->
        <joint name="left_joint1">
            <command_interface name="position"><param name="min">-2.7</param><param name="max">2.7</param></command_interface>
            <state_interface name="position"/><state_interface name="velocity"/>
        </joint>
        <joint name="left_joint2">
            <command_interface name="position"><param name="min">-1.74</param><param name="max">1.74</param></command_interface>
